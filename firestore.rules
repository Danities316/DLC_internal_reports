rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }

    // --- DailyReport Validation ---
    function isValidDailyReport(data) {
      return data.date is string && data.date.size() == 10 // YYYY-MM-DD
          && data.centreId is string && data.centreId.size() <= 100
          && data.totalProduction is int && data.totalProduction >= 0
          && data.fresh is int && data.fresh >= 0
          && data.renewal is int && data.renewal >= 0
          && data.reissue is int && data.reissue >= 0
          && data.male is int && data.male >= 0
          && data.female is int && data.female >= 0
          && (data.male + data.female == data.totalProduction)
          && (data.fresh + data.renewal + data.reissue == data.totalProduction)
          && data.classes is map
          && data.ageGroups is map
          && data.createdAt == request.time
          && data.updatedAt == request.time
          && data.createdBy == request.auth.uid;
    }

    match /dailyReports/{reportId} {
      allow get: if isSignedIn() && (
        existing().createdBy == request.auth.uid ||
        getUserData(request.auth.uid).role == 'admin'
      );
      
      allow list: if isSignedIn() && (
        resource.data.createdBy == request.auth.uid ||
        getUserData(request.auth.uid).role == 'admin'
      );

      allow create: if isSignedIn() && isValidId(reportId) && isValidDailyReport(incoming());

      allow update: if isSignedIn() && isValidId(reportId)
        && incoming().createdBy == existing().createdBy
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time
        && (
          (existing().createdBy == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['totalProduction', 'fresh', 'renewal', 'reissue', 'male', 'female', 'classes', 'ageGroups', 'remarks', 'updatedAt'])) ||
          (getUserData(request.auth.uid).role == 'admin')
        );

      allow delete: if isSignedIn() && (
        existing().createdBy == request.auth.uid ||
        getUserData(request.auth.uid).role == 'admin'
      );
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow create: if isOwner(userId) && incoming().role == 'officer'; // Default role
      allow update: if isOwner(userId) && incoming().role == existing().role; // Can't change own role
      allow delete: if false; // Users can't delete themselves
    }
  }
}
