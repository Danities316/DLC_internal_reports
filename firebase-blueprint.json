{
  "entities": {
    "DailyReport": {
      "title": "Daily Report",
      "description": "Information about daily operations at a Drivers License Centre.",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date", "description": "The date of the report (YYYY-MM-DD)" },
        "centreId": { "type": "string", "description": "The ID of the centre this report belongs to" },
        "totalProduction": { "type": "integer", "description": "Total number of licenses produced" },
        "fresh": { "type": "integer", "description": "Number of fresh applications" },
        "renewal": { "type": "integer", "description": "Number of renewals" },
        "reissue": { "type": "integer", "description": "Number of reissues" },
        "male": { "type": "integer", "description": "Number of male applicants" },
        "female": { "type": "integer", "description": "Number of female applicants" },
        "classes": {
          "type": "object",
          "properties": {
            "A": { "type": "integer" },
            "B": { "type": "integer" },
            "C": { "type": "integer" },
            "D": { "type": "integer" },
            "E": { "type": "integer" },
            "F": { "type": "integer" },
            "G": { "type": "integer" },
            "H": { "type": "integer" },
            "J": { "type": "integer" }
          }
        },
        "ageGroups": {
          "type": "object",
          "properties": {
            "18-25": { "type": "integer" },
            "26-60": { "type": "integer" },
            "60+": { "type": "integer" }
          }
        },
        "remarks": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" }
      },
      "required": ["date", "centreId", "totalProduction", "fresh", "renewal", "reissue", "male", "female", "classes", "ageGroups", "createdAt", "updatedAt", "createdBy"]
    },
    "User": {
      "title": "User Profile",
      "description": "User account information and centre association.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "centreId": { "type": "string" },
        "role": { "type": "string", "enum": ["officer", "admin"] }
      },
      "required": ["email", "centreId", "role"]
    }
  },
  "firestore": {
    "/dailyReports/{reportId}": {
      "schema": "DailyReport",
      "description": "Collection of daily operational reports."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and permissions."
    }
  }
}
